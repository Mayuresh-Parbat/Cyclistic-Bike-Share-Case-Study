import pandas as pd

# Load cleaned data
df = pd.read_csv(r"C:\Users\mayur\OneDrive\Desktop\cyclistic-case-study\data\processed\cyclistic_clean.csv")

# Overview
print("Total rides:", len(df))
print(df.head())

# Total rides by member type
rides_by_type = df["member_casual"].value_counts()
print("\nRides by rider type:\n", rides_by_type)

# Average ride length by member type
avg_ride_length = df.groupby("member_casual")["ride_length_min"].mean()
print("\nAverage ride length (min):\n", avg_ride_length)

# Most popular day of week
rides_by_day = df.groupby(["member_casual", "day_of_week"]).size().unstack().fillna(0)
print("\nRides by day of week:\n", rides_by_day)

# Monthly pattern
rides_by_month = df.groupby(["member_casual", "month"]).size().unstack().fillna(0)
print("\nRides by month:\n", rides_by_month)

# Average ride time by hour of day
hourly_pattern = df.groupby(["member_casual", "hour_of_day"]).size().unstack().fillna(0)
print("\nRides by hour of day:\n", hourly_pattern)
